# ==============================================
# PARADISO LOGISTICS - Backend Configuration
# ==============================================
# Copia este archivo como .env y completa los valores

# Entorno
NODE_ENV=development

# Servidor
PORT=3000

# Base de Datos PostgreSQL
# Desarrollo local:
DATABASE_URL=postgresql://postgres:tu_password_aqui@localhost:5432/logistica
# Producción Railway: usar ${{Postgres.DATABASE_URL}} como valor en Railway Variables

# Autenticación JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
JWT_EXPIRATION=10h

# Correo SMTP (Gmail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password_16_digitos

# Pasarela de Pagos Libélula
LIBELULA_APP_KEY=tu_app_key_libelula
LIBELULA_API_URL=https://api.libelula.bo/rest/deuda/registrar
LIBELULA_CONSULTA_URL=https://api.libelula.bo/rest/deuda/consultar

# URL pública del backend (para webhooks)
# En producción: tu dominio de Railway, ej: https://logistica-backend.up.railway.app
# En desarrollo: ngrok u otro tunnel
PUBLIC_API_URL=https://tu-dominio.up.railway.app
